{
  "name": "control-automation-engine-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development PORT=${PORT:-3001} DATABASE_URL=${DATABASE_URL:-postgresql://cae:cae_password@localhost:5433/cae} && pnpm run build && pnpm run start",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tensorflow-models/face-detection": "^1.0.3",
    "@tensorflow/tfjs-node": "^4.22.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "jimp": "^1.6.1",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "tesseract.js": "^7.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@vitest/ui": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.9"
  }
}
