PORT=3001
DATABASE_URL=postgresql://cae:cae_password@localhost:5433/cae
API_PROXY_TARGET=http://localhost:3001
PUBLIC_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:1420,http://localhost:1421
APP_AUTH_SECRET=change-me-to-a-random-64-character-secret-before-production
AUTH_TOKEN_TTL_SECONDS=604800

# NOWPayments
# Never commit a real API key or IPN secret. Regenerate any key that was shared publicly.
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_IPN_URL=

# Keep false in production. It exists only for controlled local/admin testing.
ENABLE_MANUAL_WALLET_DEPOSITS=false

# Appwrite Storage for submitted proof files
# Self-hosted endpoint. The backend adds /v1 automatically when missing.
APPWRITE_ENDPOINT=https://appwrite.run.place/
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_PROOFS_BUCKET_ID=
PROOF_MAX_FILE_BYTES=8388608

# Public Appwrite config can be used later for Realtime subscriptions.
VITE_APPWRITE_ENDPOINT=
VITE_APPWRITE_PROJECT_ID=
