PORT=3001
POSTGRES_USER=cae
POSTGRES_PASSWORD=replace_with_strong_postgres_password
POSTGRES_DB=cae
DATABASE_URL=postgresql://cae:cae_password@localhost:5433/cae
API_PROXY_TARGET=http://localhost:3001
PUBLIC_API_URL=https://wrtfm.work.gd
CORS_ORIGIN=https://wrtfm.work.gd,https://www.wrtfm.work.gd,http://localhost:1420,http://localhost:1421
APP_AUTH_SECRET=replace_with_strong_auth_secret_from_openssl_rand_hex_64
AUTH_TOKEN_TTL_SECONDS=604800

# KYC Data Encryption
# Used to encrypt sensitive KYC verification data (confidence scores, face match similarity, document analysis)
# at rest in the database. Generate a new key for production with: openssl rand -hex 32
# This key MUST be exactly 64 hex characters (32 bytes). Required in production.
# In development, if not set, a default insecure key is used with a warning.
KYC_ENCRYPTION_KEY=replace_with_64_hex_chars_from_openssl_rand_hex_32

# NOWPayments
# Never commit a real API key or IPN secret. Regenerate any key that was shared publicly.
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_API_KEY=replace_with_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=replace_with_nowpayments_ipn_secret
NOWPAYMENTS_IPN_URL=
NOWPAYMENTS_PAYOUT_EMAIL=
NOWPAYMENTS_PAYOUT_PASSWORD=
NOWPAYMENTS_PAYOUT_TOTP_SECRET=
# Optional override. If empty, backend uses PUBLIC_API_URL/api/payments/nowpayments/payout-ipn.
NOWPAYMENTS_PAYOUT_IPN_URL=
MIN_WITHDRAWAL_USD=5

# Keep false in production. It exists only for controlled local/admin testing.
ENABLE_MANUAL_WALLET_DEPOSITS=false
APPWRITE_API_KEY=replace_with_appwrite_server_api_key
APPWRITE_PROOFS_BUCKET_ID=replace_with_appwrite_bucket_id
APPWRITE_PROJECT_ID=replace_with_appwrite_project_id
APPWRITE_ENDPOINT=https://appwrite.example.com/
KYC_VISION_SERVICE_URL=http://kyc-vision-service:5010
